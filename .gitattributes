# Normalize line endings so checked-in fixtures stay stable across platforms.
# Git stores text as LF; without this, a Windows checkout (core.autocrlf=true)
# rewrites files to CRLF and byte-for-byte comparisons break.
* text=auto

# Shell scripts must stay LF; Windows batch scripts must stay CRLF.
*.sh    text eol=lf
gradlew text eol=lf
*.bat   text eol=crlf

# Binary assets git must not touch.
*.png binary
*.jar binary
